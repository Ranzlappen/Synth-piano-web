# Built application files
*.apk
*.aab
*.ap_
*.aar

# Files for the ART/Dalvik VM
*.dex

# Java / Kotlin class files
*.class

# Generated files
bin/
gen/
out/
release/

# Gradle files
.gradle/
build/

# Local configuration file (sdk path, etc)
local.properties

# Proguard folder generated by Eclipse
proguard/

# Log Files
*.log

# Android Studio Navigation editor temp files
.navigation/

# Android Studio captures folder
captures/

# IntelliJ
*.iml
.idea/
*.ipr
*.iws

# Keystore files
*.jks
*.keystore

# External native build folder generated in Android Studio 2.2 and later
.externalNativeBuild
.cxx/

# Google Services (e.g. APIs or Firebase)
google-services.json

# Version control
vcs.xml

# lint
lint/intermediates/
lint/generated/
lint/outputs/
lint/tmp/

# CMake build outputs
cmake-build-*/

# Python (source app reference)
__pycache__/
*.pyc
*.pyo

# macOS
.DS_Store

# Node (in case any tooling shows up)
node_modules/

# OS / editor
*.swp
*.swo
.vscode/
